using System;

class Program
{
    static void Main()
    {
        Console.WriteLine("=== Задание 1 ===");
        Task1();
        
        Console.WriteLine("\n=== Задание 2 ===");
        Task2();
        
        Console.WriteLine("\n=== Задание 3 ===");
        Task3();
        
        Console.WriteLine("\n=== Задание 4 ===");
        Task4();
    }
    
    // Задание 1
    static void Task1()
    {
        Console.Write("Введите A (длина прямоугольника): ");
        int A = int.Parse(Console.ReadLine());
        
        Console.Write("Введите B (ширина прямоугольника): ");
        int B = int.Parse(Console.ReadLine());
        
        Console.Write("Введите C (сторона квадрата): ");
        int C = int.Parse(Console.ReadLine());
        
        if (C > A || C > B)
        {
            Console.WriteLine("Ошибка: Невозможно разместить ни одного квадрата, так как сторона квадрата превышает размер стороны прямоугольника.");
            return;
        }
        
        int countByA = A / C;
        int countByB = B / C;
        int totalSquares = countByA * countByB;
        int unusedArea = A * B - totalSquares * C * C;
        
        Console.WriteLine($"Количество квадратов: {totalSquares}");
        Console.WriteLine($"Площадь незанятой части: {unusedArea}");
    }
    
    // Задание 2
    static void Task2()
    {
        double initialDeposit = 10000;
        double target = 11000;
        
        Console.Write("Введите процент P (0 < P < 25): ");
        double P = double.Parse(Console.ReadLine());
        
        if (P <= 0 || P >= 25)
        {
            Console.WriteLine("Ошибка: P должно быть в интервале (0, 25)");
            return;
        }
        
        double deposit = initialDeposit;
        int months = 0;
        
        while (deposit <= target)
        {
            deposit += deposit * (P / 100);
            months++;
        }
        
        Console.WriteLine($"Количество месяцев: {months}");
        Console.WriteLine($"Итоговый размер вклада: {deposit:F2}");
    }
    
    // Задание 3
    static void Task3()
    {
    Console.Write("Введите A: ");
    int A = int.Parse(Console.ReadLine());
    
    Console.Write("Введите B (A < B): ");
    int B = int.Parse(Console.ReadLine());
    
    if (A >= B)
    {
        Console.WriteLine("Ошибка: A должно быть меньше B");
        return;
    }
    
    for (int i = A; i <= B; i++)
    {
        for (int j = 0; j < i; j++)
        {
            Console.Write(i);
            if (j < i - 1) Console.Write(" ");
        }
        Console.WriteLine();
    }
}
    // Задание 4
    static void Task4()
    {
        Console.Write("Введите целое положительное число N: ");
        int N = int.Parse(Console.ReadLine());
        
        if (N <= 0)
        {
            Console.WriteLine("Ошибка: N должно быть больше 0");
            return;
        }
        
        int reversed = 0;
        int original = N;
        
        while (N > 0)
        {
            int digit = N % 10;
            reversed = reversed * 10 + digit;
            N /= 10;
        }
        
        Console.WriteLine($"Исходное число: {original}");
        Console.WriteLine($"Число справа налево: {reversed}");
    }
}
