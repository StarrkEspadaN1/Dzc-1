                Console.WriteLine("2. Демонстрация класса Point3D (наследник Point2D<int>)");
                Console.WriteLine("3. Демонстрация обобщённого класса прямой Line2D<T>");
                Console.WriteLine("4. Подсчёт частоты слов в тексте с помощью Dictionary");
                Console.WriteLine("5. Выход");
                Console.Write("Выберите задание: ");

                string choice = Console.ReadLine();
                switch (choice)
                {
                    case "1":
                        DictionaryTask.Run();
                        break;
                    case "2":

                        Point3D p = new Point3D(3, 5, 7);
                        Console.WriteLine($"Создана точка: {p}");
                        break;
                    case "3":

                        Line2D<int> intLine = new Line2D<int>(0, 0, 2, 3);
                        Console.WriteLine(intLine);

                        Line2D<double> doubleLine = new Line2D<double>(new Point2D<double>(1.5, 2.5), new Point2D<double>(3.1, 4.8));
                        Console.WriteLine(doubleLine);
                        break;
                    case "4":
                        WordCountTask.Run();
                        break;
                    case "5":
                        return;
                    default:
                        Console.WriteLine("Неверный выбор. Попробуйте снова.");
                        break;
                }
            }
        }
    }
